{
  "name": "luminous-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Deployable backend for Luminous medicine search and AI endpoints.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts --env-file=.env.development",
    "start": "node dist/server.js",
    "start:prod": "node --env-file=.env.production dist/server.js",
    "test": "set MYSQL_HOST=localhost&& set MYSQL_USER=test&& set MYSQL_DATABASE=luminous&& set JWT_SECRET=test-jwt&& set JWT_REFRESH_SECRET=test-refresh&& node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.46",
    "@langchain/openai": "^1.4.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.4",
    "redis": "^5.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
