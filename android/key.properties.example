# Copy this file to android/key.properties and fill with your real values.
# The real key.properties is ignored by git.

# Relative path from android/ directory, for example: app/release-keystore.jks
storeFile=app/release-keystore.jks
storePassword=replace_with_store_password
keyAlias=replace_with_key_alias
keyPassword=replace_with_key_password
